THE TOOLS WE IMPORT AND WHAT THEY DO

initializeApp          // Starts Firebase using your config

// FROM firebase-auth.js

getAuth                // Gets the Auth tool
createUserWithEmailAndPassword  // Creates a new account
signInWithEmailAndPassword      // Logs in an existing account
signOut                // Logs out the current user
onAuthStateChanged     // Watches if someone is logged in or not

// FROM firebase-firestore.js

getFirestore           // Gets the Database tool
doc                    // Points to a specific document location
setDoc                 // Writes/saves data to Firestore
getDoc                 // Reads one document from Firestore
collection             // Points to a group of documents
query                  // Prepares a search
where                  // The search condition (example: where lrn == "123")
getDocs                // Runs the search and returns results
  

